{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/vue/:path*", "destination": "/vue/index.html" },
    { "source": "/react/:path*", "destination": "/react/index.html" },
    { "source": "/angular/:path*", "destination": "/angular/index.html" }
  ]
}
